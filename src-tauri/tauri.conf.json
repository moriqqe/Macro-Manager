{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "MacrosManager",
  "version": "0.1.0-0",
  "identifier": "com.macros.manager",
  "build": {
    "frontendDist": "../web-root",
    "beforeDevCommand": {
      "script": "node scripts/sync-web-root.cjs",
      "cwd": "..",
      "wait": true
    },
    "beforeBuildCommand": {
      "script": "node scripts/sync-web-root.cjs",
      "cwd": ".."
    }
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "MacrosManager",
        "width": 580,
        "height": 1020,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 14, "y": 12 }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  }
}
